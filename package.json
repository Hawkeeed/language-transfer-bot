{
  "name": "language-transfer-bot",
  "version": "0.1.0",
  "description": "Desktop app to learn German using the Language Transfer / Thinking Method, powered by the OpenAI API.",
  "main": "main.js",
  "author": "Hawkeeed",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.hawkeeed.languagetransferbot",
    "productName": "Language Transfer Bot",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "data/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^31.3.1"
  },
  "dependencies": {
    "openai": "^4.56.0"
  }
}
